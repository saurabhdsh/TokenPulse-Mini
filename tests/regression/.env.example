# TokenPulse Mini — regression test credentials
# Copy to .env and fill in real values (never commit .env):
#   cp .env.example .env

# ── OpenAI (required for OpenAI regression) ───────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_ADMIN_KEY=sk-admin-...
OPENAI_ORG_ID=
OPENAI_BILLING_TOKEN=

# ── AWS Bedrock (for future regression agent) ─────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
AWS_PROFILE=default

# ── Test options ──────────────────────────────────────────────────────────────
OPENAI_USAGE_DAYS=30
OPENAI_TEST_BILLING=false

# Live prompt test — sends a tiny chat completion to generate real tokens
OPENAI_TRIGGER_USAGE=true
OPENAI_TRIGGER_MODEL=gpt-4o-mini
OPENAI_TRIGGER_PROMPT=Hello from TokenPulse regression test. Reply with one word only.
OPENAI_TRIGGER_MAX_TOKENS=10
# Seconds to poll usage API after prompt (OpenAI can lag 1–3 min)
OPENAI_USAGE_POLL_SECONDS=120
OPENAI_USAGE_POLL_INTERVAL=15
